{
  "$schema": "https://json.schemastore.org/package.json",
  "name": "oc-plugin-vault-tec",
  "version": "0.1.0",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kommander/oc-plugin-vault-tec.git"
  },
  "exports": {
    "./server": {
      "import": "./server.ts",
      "config": {
        "enabled": true,
        "mode": "append"
      }
    },
    "./tui": {
      "import": "./tui.tsx",
      "config": {
        "enabled": true,
        "set_theme": true,
        "scanlines": true,
        "scanline_speed": 0.012,
        "vignette": 0.75,
        "sidebar": true,
        "tips": true
      }
    }
  },
  "engines": {
    "opencode": ">=1.3.13"
  },
  "peerDependencies": {
    "@opencode-ai/plugin": "*",
    "@opentui/core": "*",
    "@opentui/solid": "*",
    "solid-js": "*"
  }
}
